// add number

function temp(n) {
  if (n == 1) return 1;
  return n + temp(n - 1);
}
console.log(temp(10));

// factorial

function temp(n) {
  if (n == 1) return 1;
  return n * temp(n - 1);
}
console.log(temp(10));

// febonacci

function temp(n) {
  if (n === 0 || n === 1) return n;
  return temp(n - 1) + temp(n - 2);
}

console.log(temp(4));


// GCD/HCF

function hcf(a, b) {
  let n = Math.min(a, b)
  console.log("🚀 ~ hcf ~ n:", n)
  for (let i = n; i >= 1; i--) {
    if (a % i === 0 && b % i === 0) {
      return i;
    }
  }
}

console.log(hcf(32, 20));

// or

function hcf(a, b) {
  if (a === b) {
    return a;
  } else if (a > b) {
    return hcf(a - b, b);
  } else {
    return hcf(a, b - a);
  }
}

console.log(hcf(32, 20));

