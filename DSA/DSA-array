// Move non-zero elements forward
for (let i = 0; i < arr.length; i++) {
  if (arr[i] !== 0) {
    arr[j] = arr[i];
    j++;
  }
}

// Fill remaining with zeros
for (let i = j; i < arr.length; i++) {
  arr[i] = 0;
}

