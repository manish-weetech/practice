let n = arr.length;
for (let i = 0; i < n - 1; i++) {
  for (let j = 0; j < n - i - 1; j++) {
    if (arr[j] > arr[j + 1]) {
      let temp = arr[j];
      arr[j] = arr[j + 1];
      arr[j + 1] = temp;
    }
  }
}

console.log(arr);

// Selection Sort
// It work on index mainly
// We create sorted and unsorted part in array
// left side me apne minimum value ki index find karege under 
// ke loop me or loop ke bahar nikal ke swipe karege 1st i 1st loop ke liye bahar ke 
// fir same 2nd ke liye krege minimum find krege or swipe krege

let arr = [10, 5, 12, 1, 3];
let n = arr.length;
for (let i = 0; i < n - 1; i++) {
  let minIndex = i;
  for (let j = i + 1; j < n; j++) {
    if (arr[minIndex] > arr[j]) {
      minIndex = j;
    }
  }
  if (minIndex != i) {
    let temp = arr[minIndex];
    arr[minIndex] = arr[i];
    arr[i] = temp;
  }
}

console.log(arr);

// Insert Sort
// Suppose 1st arr[0] sorted part hai to 
// left se 1st uthavo or left side sorted rakho
  
let arr = [10, 5, 12, 1, 3];
let n = arr.length;
for (let i = 1; i < n; i++) {
  let key = arr[i];
  let j = i - 1;
  while (j >= 0 && arr[j] > key) {
    arr[j + 1] = arr[j];
    j--;
  }
  arr[j + 1] = key;
}

console.log(arr);


